PORT=5000
NODE_ENV=development
APP_URL=http://localhost:3000

# PostgreSQL – Heroku Postgres sætter DATABASE_URL automatisk på Heroku
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/plannio
# PGSSLMODE=require  # kun nødvendigt på Heroku Postgres

# Session (generér en tilfældig streng)
SESSION_SECRET=skift-mig-til-en-lang-tilfaeldig-streng

# Discord OAuth – opret app på https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5000/api/auth/discord/callback

# Discord webhook-integration (poll-opdateringer i en kanal)
# Tilføj denne som en ekstra Redirect i Discord-appens OAuth2-indstillinger
DISCORD_WEBHOOK_REDIRECT_URI=http://localhost:5000/api/integrations/discord/callback

# Slack OAuth – opret app på https://api.slack.com/apps
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:5000/api/auth/slack/callback
SLACK_WEBHOOK_REDIRECT_URI=http://localhost:5000/api/integrations/slack/callback

# Prerender (valgfrit – sæt til 1 for at springe over lokalt)
# SKIP_PRERENDER=1

# Analytics (valgfrit – tilføj script-URL når du har oprettet konto, fx Plausible/Umami)
# VITE_ANALYTICS_SCRIPT=https://analytics.example.com/script.js
# VITE_ANALYTICS_WEBSITE_ID=
