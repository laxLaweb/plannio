{
  "name": "plannio",
  "version": "1.0.0",
  "private": true,
  "description": "Plannio – Node.js API med React frontend",
  "workspaces": [
    "client"
  ],
  "engines": {
    "node": "24.x",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "optimize-og": "node scripts/optimize-og.mjs",
    "generate-sitemap": "node scripts/generate-sitemap.mjs",
    "generate-llms": "node scripts/generate-llms.mjs",
    "generate-seo": "npm run generate-sitemap && npm run generate-llms",
    "build": "npm run optimize-og && npm run generate-seo && npm run build -w plannio-client",
    "heroku-postbuild": "npm run build && npm run prerender",
    "prerender": "node scripts/prerender.mjs",
    "start": "node server/index.js",
    "db:migrate": "node server/db/migrate.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch-path=./server server/index.js",
    "dev:client": "npm run dev -w plannio-client"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.1",
    "pg": "^8.14.1"
  },
  "devDependencies": {
    "@sparticuz/chromium": "^149.0.0",
    "concurrently": "^9.1.2",
    "puppeteer": "^25.3.0",
    "puppeteer-core": "^25.3.0",
    "sharp": "^0.35.3"
  }
}
